<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<!-- collegamento al foglio di stile CSS -->
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="it.unicam.cs.mpgc.rpg125730.controller.GameViewController" stylesheets="@../../../../../../style.css">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- TOP: salvataggi e compendio -->
    <top>
        <VBox spacing="10" alignment="CENTER">
            <HBox spacing="10" alignment="CENTER">
                <Button text="Nuova Partita" onAction="#onNewGame" styleClass="btn-new-game"/>
                <Button text="Salva Partita" onAction="#onSaveGame" styleClass="btn-save-load"/>
                <Button text="Carica Partita" onAction="#onLoadGame" styleClass="btn-save-load"/>
                <Button text="Apri Compendio" onAction="#onOpenCompendium" styleClass="btn-compendium"/>
            </HBox>

            <Label fx:id="roomLabel" text="Stanza: 1" styleClass="room-label"/>

            <Label fx:id="playerStatsLabel" text="Joker - Sanity | Focus"/>
            <ProgressBar fx:id="playerSanityBar" progress="1.0" prefWidth="300" maxWidth="Infinity" styleClass="sanity-bar-player"/>
            <ProgressBar fx:id="playerFocusBar" progress="1.0" prefWidth="300" maxWidth="Infinity" styleClass="focus-bar-player"/>

            <Label fx:id="enemyStatsLabel" text="Ombra - Sanity"/>
            <ProgressBar fx:id="enemySanityBar" progress="1.0" prefWidth="300" maxWidth="Infinity" styleClass="sanity-bar-enemy"/>
        </VBox>
    </top>

    <!-- CENTER: immagini e log di combattimento -->
    <center>
        <VBox alignment="CENTER" spacing="15">
            <BorderPane.margin>
                <Insets top="15" bottom="15"/>
            </BorderPane.margin>

            <HBox alignment="CENTER" spacing="50">
                <ImageView fx:id="playerImageView" fitWidth="150" fitHeight="200" preserveRatio="true"/>
                <Label text="VS" styleClass="vs-label"/>
                <ImageView fx:id="enemyImageView" fitWidth="150" fitHeight="200" preserveRatio="true"/>
            </HBox>

            <TextArea fx:id="combatLogArea" editable="false" wrapText="true" prefHeight="200" maxHeight="Infinity"/>
        </VBox>
    </center>

    <!-- BOTTOM: bottoni d'Azione -->
    <bottom>
        <HBox fx:id="combatButtonsBox" spacing="15" alignment="CENTER">
            <Button text="Attacco Fisico" onAction="#onPhysicalAttack" prefWidth="150" prefHeight="40" styleClass="btn-physical"/>
            <Button text="Skill Fuoco" onAction="#onFireSkill" prefWidth="150" prefHeight="40" styleClass="btn-fire"/>
            <Button text="Skill Ghiaccio" onAction="#onIceSkill" prefWidth="150" prefHeight="40" styleClass="btn-ice"/>
            <Button text="Sovraccarico Cog." onAction="#onCognitiveSkill" prefWidth="150" prefHeight="40" styleClass="btn-cognitive"/>
            <Button text="Stabilizza" onAction="#onHeal" prefWidth="150" prefHeight="40" styleClass="btn-heal"/>
        </HBox>
    </bottom>
</BorderPane>